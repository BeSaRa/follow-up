{
  "name": "follow-up",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/follow-up/src",
  "tags": ["type:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "externalDependencies": [
          "fonts/Lusail-Regular.otf",
          "fonts/Lusail-Regular.woff",
          "fonts/Lusail-Regular.woff2",
          "fonts/Lusail-Regular.ttf",
          "fonts/Lusail-Medium.otf",
          "fonts/Lusail-Medium.woff",
          "fonts/Lusail-Medium.woff2",
          "fonts/Lusail-Medium.ttf",
          "fonts/Lusail-Light.otf",
          "fonts/Lusail-Light.woff",
          "fonts/Lusail-Light.woff2",
          "fonts/Lusail-Light.ttf",
          "fonts/Lusail-Bold.otf",
          "fonts/Lusail-Bold.woff",
          "fonts/Lusail-Bold.woff2",
          "fonts/Lusail-Bold.ttf"
        ],
        "outputPath": "dist/apps/follow-up",
        "browser": "apps/follow-up/src/main.ts",
        "tsConfig": "apps/follow-up/tsconfig.app.json",
        "allowedCommonJsDependencies": ["qs"],
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/follow-up/public"
          },
          {
            "glob": "**/*",
            "input": "apps/follow-up/src/fonts",
            "output": "fonts"
          }
        ],
        "styles": [
          "apps/follow-up/src/fonts.css",
          "apps/follow-up/src/rtl.css",
          "apps/follow-up/src/styles.css"
        ]
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/follow-up/src/app/dev.routes.ts",
              "with": "apps/follow-up/src/app/dev.routes.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1mb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "follow-up:build:production"
        },
        "development": {
          "buildTarget": "follow-up:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "follow-up:build",
        "port": 4200,
        "staticFilePath": "dist/apps/follow-up/browser",
        "spa": true
      }
    }
  }
}
